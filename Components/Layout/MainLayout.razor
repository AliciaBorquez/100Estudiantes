@inherits LayoutComponentBase

<MudThemeProvider Theme="_neonTheme" IsDarkMode="true" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <NavMenu />
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pt-4 pb-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    MudTheme _neonTheme = new MudTheme()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#5F49F2",
            Secondary = "#D93DAF",
            Tertiary = "#8124BF",
            Info = "#79F2F2",
            Background = "12151D",
            AppbarBackground = "#1E1F72",
            TextPrimary = "#FFFFFF",
            DrawerBackground = "#051026"
        }
    };
}