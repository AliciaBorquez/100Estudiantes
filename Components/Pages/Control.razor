@page "/"
@using CienEstudiantesDijeron.Data
@using CienEstudiantesDijeron.Models

@inject JuegoService Juego
@inject ApplicationDbContext DbContext
@inject IJSRuntime JSRuntime

@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Control Juego</PageTitle>

<div class="d-flex flex-column mb-8">
    <MudText Typo="Typo.h2" Color="Color.Primary" Style="font-weight: bold;">
        Panel de Control
    </MudText>
    
    <MudButton Variant="Variant.Filled" 
                Color="Color.Secondary" 
                Size="Size.Large" 
                StartIcon="@Icons.Material.Filled.Monitor" 
                OnClick="AbrirVentana"
                Class="mt-2"
                Style="align-self: flex-start; border-radius: 8px; font-weight: bold; padding: 10px 24px;">
        ABRIR TABLERO
    </MudButton>
</div>

@if (!partidaEnCurso)
{
    <MudPaper Elevation="8" Class="pa-6 rounded-lg mb-8" Style="background-color: rgba(5, 16, 38, 0.6); border: 1px solid #79F2F2;">
        
        <MudText Typo="Typo.h4" Color="Color.Info" Class="mb-6" Style="font-weight: bold;">
            Configuración de Partida
        </MudText>

        <MudGrid Spacing="4" Class="align-center">
            
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="nombreTmp1" 
                                Label="Nombre Equipo 1" 
                                Variant="Variant.Outlined" 
                                Adornment="Adornment.Start" 
                                AdornmentIcon="@Icons.Material.Filled.Group" />
            </MudItem>
            
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="nombreTmp2" 
                                Label="Nombre Equipo 2" 
                                Variant="Variant.Outlined" 
                                Adornment="Adornment.Start" 
                                AdornmentIcon="@Icons.Material.Filled.Group" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudNumericField @bind-Value="cantidadRondas" 
                                    Label="Número de Rondas" 
                                    Min="1" 
                                    Variant="Variant.Outlined" 
                                    Adornment="Adornment.Start" 
                                    AdornmentIcon="@Icons.Material.Filled.FormatListNumbered" />
            </MudItem>
            
        </MudGrid>

        <div class="d-flex justify-end mt-6">
            <MudButton Variant="Variant.Filled" 
                        Color="Color.Primary" 
                        Size="Size.Large" 
                        EndIcon="@Icons.Material.Filled.SportsEsports" 
                        OnClick="ComenzarPartida"
                        Style="border-radius: 8px; font-weight: bold; padding: 12px 30px;">
                Comenzar Partida
            </MudButton>
        </div>
        
    </MudPaper>
}

@if (partidaEnCurso)
{
    @if (Juego.PartidaTerminada) 
    {
        <MudPaper Elevation="8" Class="pa-8 rounded-lg" Style="background-color: rgba(5, 16, 38, 0.8); border: 2px dashed #79F2F2; text-align: center;">
            <MudText Typo="Typo.h2" Color="Color.Success" Style="font-weight: bold;" Class="mb-4">
                ¡PARTIDA FINALIZADA!
            </MudText>
            
            <div class="d-flex justify-center mb-6">
                <MudSimpleTable Style="background-color: rgba(0,0,0,0.4); border: 1px solid #79F2F2; width: 100%; max-width: 400px;" Class="rounded-lg">
                    <thead>
                        <tr>
                            <th><MudText Typo="Typo.h6" Color="Color.Info" Style="font-weight: bold;">Equipo</MudText></th>
                            <th><MudText Typo="Typo.h6" Color="Color.Info" Style="font-weight: bold;">Puntaje Total</MudText></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr style="@(Juego.puntosEquipo1 >= Juego.puntosEquipo2 ? "background-color: rgba(121, 242, 242, 0.2);" : "")">
                            <td><MudText Typo="Typo.h6" Style="color: white;">@Juego.Equipo1</MudText></td>
                            <td><MudText Typo="Typo.h6" Style="color: white; font-weight: bold;">@Juego.puntosEquipo1 pts</MudText></td>
                        </tr>
                        <tr style="@(Juego.puntosEquipo2 >= Juego.puntosEquipo1 ? "background-color: rgba(121, 242, 242, 0.2);" : "")">
                            <td><MudText Typo="Typo.h6" Style="color: white;">@Juego.Equipo2</MudText></td>
                            <td><MudText Typo="Typo.h6" Style="color: white; font-weight: bold;">@Juego.puntosEquipo2 pts</MudText></td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </div>

            <MudPaper Elevation="0" Class="pa-4 mx-auto mb-6 rounded-lg" Style="background-color: rgba(40, 167, 69, 0.2); border: 1px solid #28a745; max-width: 400px;">
                <MudText Typo="Typo.h5" Style="color: white;">
                    <strong>GANADOR: </strong> 
                    <span style="color: #79F2F2; font-weight: bold; font-size: 1.5rem;">
                        @(Juego.puntosEquipo1 > Juego.puntosEquipo2 ? Juego.Equipo1 : (Juego.puntosEquipo2 > Juego.puntosEquipo1 ? Juego.Equipo2 : "EMPATE"))
                    </span>
                </MudText>
            </MudPaper>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="ResetearParaNuevaPartida" Style="border-radius: 8px; font-weight: bold; padding: 10px 24px;">
                VOLVER AL INICIO (NUEVA PARTIDA)
            </MudButton>
        </MudPaper>
    }

    else
    {
        <MudPaper Elevation="8" Class="pa-6 rounded-lg mb-8" Style="background-color: rgba(5, 16, 38, 0.6); border: 1px solid #79F2F2;">
            
            <div class="d-flex justify-space-between align-center mb-6">
                <MudText Typo="Typo.h3" Color="Color.Info" Style="font-weight: bold;">
                    Ronda @rondaActual de @cantidadRondas
                </MudText>
                
                <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.StopCircle" OnClick="FinalizarPartida" Style="border-radius: 8px; font-weight: bold;">
                    Finalizar Partida
                </MudButton>
            </div>

            <div class="d-flex flex-column align-center mb-8">
                <MudText Typo="Typo.h5" Style="color: #ffffff; font-weight: 500;" Class="mb-3">Puntos de la Ronda</MudText>
                <MudPaper Elevation="6" Class="pa-4 d-flex justify-center align-center rounded-lg" Style="background-color: #0820A6; border: 3px solid #D93DAF; min-width: 200px; min-height: 100px;">
                    <MudText Typo="Typo.h1" Style="color: #ffffff; font-weight: bold;">@Juego.puntosPartida</MudText>
                </MudPaper>
            </div>

            <MudSimpleTable Style="background-color: rgba(0,0,0,0.2); border: 1px solid #8124BF;" Class="mb-6 rounded-lg">
                <thead>
                    <tr>
                        <th><MudText Typo="Typo.h6" Color="Color.Info" Style="font-weight: bold;">Equipo</MudText></th>
                        <th><MudText Typo="Typo.h6" Color="Color.Info" Style="font-weight: bold;">Puntos</MudText></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><MudText Typo="Typo.h6" Style="color: #ffffff;">@Juego.Equipo1</MudText></td>
                        <td><MudText Typo="Typo.h6" Style="color: #ffffff; font-weight: bold;">@Juego.puntosEquipo1</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Typo="Typo.h6" Style="color: #ffffff;">@Juego.Equipo2</MudText></td>
                        <td><MudText Typo="Typo.h6" Style="color: #ffffff; font-weight: bold;">@Juego.puntosEquipo2</MudText></td>
                    </tr>
                </tbody>
            </MudSimpleTable>

            <MudDivider Class="my-6" Style="border-color: #8124BF; border-width: 2px;" />

            @if (string.IsNullOrEmpty(Juego.PreguntaActual))
            {
                <div class="d-flex justify-end">
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large" EndIcon="@Icons.Material.Filled.LiveHelp" OnClick="CargarPreguntaAleatoria" Style="border-radius: 8px; font-weight: bold; padding: 12px 30px;">
                        Generar Pregunta
                    </MudButton>
                </div>
            }
            else
            {
                <div class="d-flex align-center justify-space-between mb-6 mt-4">
                    <MudText Typo="Typo.h3" Color="Color.Info" Style="font-weight: bold;">
                        Multiplicación de puntos
                    </MudText>
                    
                    <div class="d-flex align-center gap-3">
                        @foreach (var m in new int[] { 1, 2, 3 })
                        {
                            Color colorActivo = m == 1 ? Color.Info : (m == 2 ? Color.Tertiary : Color.Secondary);
                            bool seleccionado = Juego.Multiplicador == m;
                            
                            <MudButton OnClick="() => Juego.SetMultiplicador(m)"
                                        Disabled="@Juego.PreguntaRevelada"
                                        Variant="@(seleccionado ? Variant.Filled : Variant.Outlined)"
                                        Color="@(seleccionado ? colorActivo : Color.Default)"
                                        Style="@(!seleccionado ? "color: white; border-color: rgba(255,255,255,0.3);" : "font-weight: bold;")"
                                        Size="Size.Large">
                                x @m
                            </MudButton>
                        }
                    </div>
                </div>

                <MudPaper Elevation="4" Class="pa-8 mb-6 rounded-lg d-flex flex-column align-center" Style="background-color: rgba(0,0,0,0.5); border: 2px solid #8124BF;">
                    <MudText Typo="Typo.h4" Style="color: #ffffff; text-align: center; font-weight: bold;" Class="mb-8">
                        @Juego.PreguntaActual
                    </MudText>

                    @if (!Juego.PreguntaRevelada)
                    {
                        <MudButton Variant="Variant.Filled" 
                                    Color="Color.Secondary" 
                                    Size="Size.Large" 
                                    StartIcon="@Icons.Material.Filled.Visibility"
                                    OnClick="() => Juego.RevelarPregunta()"
                                    Style="border-radius: 8px; font-weight: bold; padding: 15px 40px; font-size: 1.2rem;">
                            REVELAR PREGUNTA AL TABLERO
                        </MudButton>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Class="px-4">
                            Pregunta visible en tablero
                        </MudChip>
                    }
                </MudPaper>

                @if (Juego.PreguntaRevelada) 
                {
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudText Typo="Typo.h5" Style="color: white; font-weight: bold;">
                            Respuestas (Presiona para revelar)
                        </MudText>

                        <div class="d-flex align-center gap-2">
                            @if (Juego.TimerActivo)
                            {
                                <MudChip T="string" Color="Color.Error" Variant="Variant.Filled" OnClose="@(() => Juego.CancelarTimer())">
                                    TIMER: @Juego.TiempoRestante s (@Juego.EquipoConTimer)
                                </MudChip>
                            }
                            else
                            {
                                <MudMenu Label="Timer 10s" 
                                        Color="Color.Warning" 
                                        Variant="Variant.Filled" 
                                        StartIcon="@Icons.Material.Filled.Timer"
                                        EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                                        Disabled="@(Juego.puntosAsignadosEnRonda || !Juego.PreguntaRevelada)">
                                    <MudMenuItem OnClick="@(() => Juego.IniciarTimer(Juego.Equipo1))">Para @Juego.Equipo1</MudMenuItem>
                                    <MudMenuItem OnClick="@(() => Juego.IniciarTimer(Juego.Equipo2))">Para @Juego.Equipo2</MudMenuItem>
                                </MudMenu>
                            }
                        </div>
                    </div>

                    <MudGrid Spacing="2" Class="mb-6">
                        @foreach (var respuesta in Juego.RespuestasActuales)
                        {
                            bool revelada = Juego.RespuestasReveladas.Contains(respuesta.res_respuesta);
                            <MudItem xs="12" sm="6">
                                <MudButton FullWidth="true" 
                                            Variant="Variant.Filled"
                                            OnClick="() => Juego.RevelarRespuestaPorTexto(respuesta.res_respuesta)"
                                            Style="@(revelada ? "background-color: #28a745; color: white; justify-content: flex-start; padding: 15px;" : "background-color: #0820A6; color: white; justify-content: flex-start; padding: 15px; border: 1px solid #79F2F2;")">
                                    <div class="d-flex justify-space-between" style="width: 100%;">
                                        <span style="font-weight: bold; font-size: 1.1rem;">@respuesta.res_respuesta</span>
                                        <span>
                                            (@respuesta.res_cantidad pts)
                                            @if (Juego.Multiplicador > 1)
                                            {
                                                <span style="color: #ffff00; font-weight: bold; margin-left: 8px;">➔ @Juego.ObtenerPuntosMultiplicados(respuesta.res_cantidad) pts</span>
                                            }
                                        </span>
                                    </div>
                                </MudButton>
                            </MudItem>
                        }
                    </MudGrid>

                    <MudGrid Spacing="4" Class="mb-6">
                        <MudItem xs="6">
                            <MudPaper Class="pa-4 text-center" Style="background-color: rgba(217, 61, 175, 0.1); border: 1px solid #D93DAF;">
                                <MudText Typo="Typo.h6" Style="color: white;">Errores @Juego.Equipo1</MudText>
                                <MudText Typo="Typo.h4" Color="Color.Error" Style="font-weight: bold;" Class="my-2">
                                    @(Juego.ErroresEquipo1 > 0 ? string.Concat(Enumerable.Repeat("X ", Juego.ErroresEquipo1)) : "-")
                                </MudText>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick='() => Juego.AgregarError(Juego.Equipo1)'>
                                    Marcar Error
                                </MudButton>
                            </MudPaper>
                        </MudItem>
                        
                        <MudItem xs="6">
                            <MudPaper Class="pa-4 text-center" Style="background-color: rgba(217, 61, 175, 0.1); border: 1px solid #D93DAF;">
                                <MudText Typo="Typo.h6" Style="color: white;">Errores @Juego.Equipo2</MudText>
                                <MudText Typo="Typo.h4" Color="Color.Error" Style="font-weight: bold;" Class="my-2">
                                    @(Juego.ErroresEquipo2 > 0 ? string.Concat(Enumerable.Repeat("X ", Juego.ErroresEquipo2)) : "-")
                                </MudText>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick='() => Juego.AgregarError(Juego.Equipo2)'>
                                    Marcar Error
                                </MudButton>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    <MudPaper Class="pa-4 mb-6 d-flex justify-space-around align-center" Style="background-color: rgba(121, 242, 242, 0.1); border: 1px dashed #79F2F2;">
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(Juego.puntosAsignadosEnRonda || Juego.puntosPartida == 0)" OnClick="() => Juego.AsignarPuntosEquipo(Juego.Equipo1, rondaActual)">
                            @(Juego.puntosAsignadosEnRonda ? "Entregados" : $"Entregar {Juego.puntosPartida} pts a {Juego.Equipo1}")
                        </MudButton>
                        
                        @if (Juego.puntosAsignadosEnRonda)
                        {
                            <MudText Color="Color.Success" Style="font-weight: bold;"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" />Puntos asignados</MudText>
                        }

                        <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(Juego.puntosAsignadosEnRonda || Juego.puntosPartida == 0)" OnClick="() => Juego.AsignarPuntosEquipo(Juego.Equipo2, rondaActual)">
                            @(Juego.puntosAsignadosEnRonda ? "Entregados" : $"Entregar {Juego.puntosPartida} pts a {Juego.Equipo2}")
                        </MudButton>
                    </MudPaper>
                }

                <div class="d-flex justify-end mt-8">
                    <MudButton Variant="Variant.Filled" 
                                Color="Color.Primary" 
                                EndIcon="@Icons.Material.Filled.SkipNext" 
                                OnClick="SiguienteRonda"
                                Style="border-radius: 8px; font-weight: bold; padding: 10px 24px;">
                        @(rondaActual < cantidadRondas ? "Saltar Ronda" : "FINALIZAR Y VER GANADOR")
                    </MudButton>
                </div>
            }
        </MudPaper>
    }
}

@code {
    private string nombreTmp1 = "";
    private string nombreTmp2 = "";

    private int cantidadRondas = 3;
    private int rondaActual = 0;

    private bool partidaEnCurso = false;

    private List<int> preguntasUsadas = new List<int>();

    protected override void OnInitialized()
    {
        Juego.OnChange += ManejarCambioEstado;
    }

    private async void ManejarCambioEstado()
    {
        try
        {
            // InvokeAsync asegura que volvamos al hilo del navegador correspondiente
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception)
        {
        }
    }

    public void Dispose()
    {
        Juego.OnChange -= ManejarCambioEstado;
    }

    private void ComenzarPartida()
    {
        if (string.IsNullOrWhiteSpace(nombreTmp1) || string.IsNullOrWhiteSpace(nombreTmp2) || cantidadRondas <= 0)
        {
            return;
        }

        Juego.ActualizarNombres(nombreTmp1, nombreTmp2);
        partidaEnCurso = true;
        rondaActual = 1;
        Juego.LimpiarPregunta(); 
    }

    private void SiguienteRonda()
    {
        if (rondaActual < cantidadRondas)
        {
            rondaActual++;
            Juego.LimpiarPregunta();
        }
        else
        {
            Juego.FinalizarPartida();
        }
    }

    private void ResetearParaNuevaPartida()
    {
        partidaEnCurso = false;
        rondaActual = 0;
        preguntasUsadas.Clear();
        nombreTmp1 = "";
        nombreTmp2 = "";
        Juego.ReiniciarTodo();
    }

    private void FinalizarPartida()
    {
        Juego.FinalizarPartida();

    }

    private void CargarPreguntaAleatoria()
    {
        var preguntasDisponibles = DbContext.Preguntas
            .Where(p => !preguntasUsadas.Contains(p.pr_id))
            .ToList();

        if (!preguntasDisponibles.Any())
        {
            preguntasUsadas.Clear();
            preguntasDisponibles = DbContext.Preguntas.ToList();
        }

        if (preguntasDisponibles.Any())
        {
            var random = new Random();
            var preguntaAleatoria = preguntasDisponibles[random.Next(preguntasDisponibles.Count)];
            var respuestas = DbContext.Respuestas.Where(r => r.pr_id == preguntaAleatoria.pr_id).ToList();
            
            preguntasUsadas.Add(preguntaAleatoria.pr_id);
            Juego.ActualizarJuego(preguntaAleatoria.pr_pregunta, preguntaAleatoria.pr_id, respuestas);
        }
    }

    private async Task AbrirVentana()
    {
        await JSRuntime.InvokeVoidAsync("openWindow", "/tablero", "Nueva Ventana", 1366, 768);
    }
}