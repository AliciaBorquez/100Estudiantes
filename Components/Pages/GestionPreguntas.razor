@page "/gestionar"
@using Microsoft.EntityFrameworkCore
@using CienEstudiantesDijeron.Data
@using CienEstudiantesDijeron.Models
@inject ApplicationDbContext Context
@rendermode InteractiveServer

<PageTitle>Gestion Preguntas</PageTitle>

<div class="d-flex flex-column mb-6">
    <MudText Typo="Typo.h2" Color="Color.Primary" Style="font-weight: bold; text-transform: uppercase;">
        Gestión de Contenido
    </MudText>
    <MudText Typo="Typo.subtitle1" Style="color: #79F2F2;">
        Para agregar contenido nuevo, utiliza la sección de 
        <MudLink Href="/importar" Color="Color.Secondary" Style="font-weight: bold; text-decoration: underline;">Importación CSV</MudLink>.
    </MudText>
</div>

@if (preguntas == null)
{
    <div class="d-flex justify-center my-8">
        <MudProgressCircular Color="Color.Tertiary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else
{
    <MudPaper Elevation="8" Class="pa-6 rounded-lg mb-8" Style="background-color: rgba(5, 16, 38, 0.6); border: 1px solid #8124BF;">
        
        <MudTextField @bind-Value="textoBusqueda" 
                        Label="Buscar pregunta..." 
                        Variant="Variant.Outlined" 
                        Adornment="Adornment.Start" 
                        AdornmentIcon="@Icons.Material.Filled.Search"
                        IconSize="Size.Medium"
                        Clearable="true"
                        Immediate="true"
                        Class="mb-6" />

        @foreach (var p in PreguntasFiltradas)
        {
            <MudPaper Elevation="4" Class="mb-4 rounded-lg overflow-hidden" Style="background-color: rgba(0,0,0,0.4); border: 1px solid #79F2F2;">
                
                <div class="d-flex justify-space-between align-center pa-4" 
                        style="cursor:pointer; background: @(preguntaAbiertaId == p.pr_id ? "rgba(121, 242, 242, 0.15)" : "rgba(0,0,0,0.2)"); transition: background 0.3s ease;" 
                        @onclick="() => Alternar(p.pr_id)">
                    
                    <MudText Typo="Typo.h6" Style="color: white; font-weight: bold;">@p.pr_pregunta</MudText>
                    <MudIcon Icon="@(preguntaAbiertaId == p.pr_id ? Icons.Material.Filled.RemoveCircleOutline : Icons.Material.Filled.AddCircleOutline)" Color="Color.Info" />
                </div>

                <MudCollapse Expanded="@(preguntaAbiertaId == p.pr_id)">
                    <div class="pa-6" style="border-top: 1px solid #79F2F2;">
                        
                        <div class="d-flex gap-4 mb-6 align-center flex-wrap">
                            <div style="flex-grow: 1;">
                                <MudTextField @bind-Value="p.pr_pregunta" Variant="Variant.Outlined" Label="Modificar texto de la pregunta" FullWidth="true" />
                            </div>
                            <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Save" OnClick="() => GuardarP(p)" Style="height: 56px; font-weight: bold;">
                                Actualizar
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever" OnClick="() => BorrarP(p)" Style="height: 56px; font-weight: bold;">
                                Eliminar Todo
                            </MudButton>
                        </div>

                        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-3" Style="font-weight: bold; text-transform: uppercase;">
                            Respuestas Asociadas
                        </MudText>
                        
                        <MudSimpleTable Style="background-color: rgba(0,0,0,0.3); border: 1px solid #D93DAF;" Class="rounded-lg">
                            <thead>
                                <tr>
                                    <th><MudText Color="Color.Secondary" Style="font-weight: bold;">Respuesta</MudText></th>
                                    <th style="width: 150px;"><MudText Color="Color.Secondary" Style="font-weight: bold;">Puntos</MudText></th>
                                    <th style="width: 80px; text-align: center;"><MudText Color="Color.Secondary" Style="font-weight: bold;">Guardar</MudText></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (respDict.ContainsKey(p.pr_id))
                                {
                                    @foreach (var r in respDict[p.pr_id])
                                    {
                                        <tr>
                                            <td>
                                                <MudTextField @bind-Value="r.res_respuesta" Variant="Variant.Text" Style="color: white;" />
                                            </td>
                                            <td>
                                                <MudNumericField @bind-Value="r.res_cantidad" Variant="Variant.Text" Style="color: #FFFF00; font-weight: bold;" />
                                            </td>
                                            <td style="text-align: center;">
                                                <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Success" OnClick="() => GuardarR(r)" Title="Guardar respuesta" />
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </MudSimpleTable>
                        
                    </div>
                </MudCollapse>
            </MudPaper>
        }
        
        @if (!PreguntasFiltradas.Any())
        {
            <MudText Typo="Typo.h6" Style="color: rgba(255,255,255,0.5); text-align: center;" Class="my-4">
                No se encontraron preguntas que coincidan con la búsqueda.
            </MudText>
        }

    </MudPaper>
}

@code {
    private List<Pregunta>? preguntas;
    private Dictionary<int, List<Respuesta>> respDict = new();
    private int? preguntaAbiertaId;

    private string textoBusqueda = "";

    private IEnumerable<Pregunta> PreguntasFiltradas =>
        string.IsNullOrWhiteSpace(textoBusqueda) || preguntas == null
            ? preguntas ?? Enumerable.Empty<Pregunta>()
            : preguntas.Where(p => p.pr_pregunta.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() => await CargarDatos();

    private void Alternar(int id) => preguntaAbiertaId = (preguntaAbiertaId == id) ? null : id;

    private async Task CargarDatos()
    {
        preguntas = await Context.Preguntas.AsNoTracking().ToListAsync();
        var respuestas = await Context.Respuestas.AsNoTracking().ToListAsync();
        
        respDict = preguntas.ToDictionary(
            p => p.pr_id, 
            p => respuestas.Where(r => r.pr_id == p.pr_id).ToList()
        );
        StateHasChanged();
    }

    private async Task BorrarP(Pregunta p)
    {
        try 
        {
            var id = p.pr_id;
            await Context.Database.ExecuteSqlRawAsync("DELETE FROM Respuestas WHERE pr_id = {0}", id);
            await Context.Database.ExecuteSqlRawAsync("DELETE FROM Preguntas WHERE pr_id = {0}", id);

            Context.ChangeTracker.Clear();
            preguntaAbiertaId = null;
            await CargarDatos();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al borrar: {ex.Message}");
        }
    }

    private async Task GuardarP(Pregunta p) 
    { 
        Context.Preguntas.Update(p); 
        await Context.SaveChangesAsync(); 
        Context.ChangeTracker.Clear();
        await CargarDatos(); 
    }

    private async Task GuardarR(Respuesta r) 
    { 
        Context.Respuestas.Update(r); 
        await Context.SaveChangesAsync(); 
        Context.ChangeTracker.Clear();
        await CargarDatos();
    }
}