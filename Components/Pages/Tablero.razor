@page "/tablero"
@layout Layout.LayoutSinNav
@inject JuegoService Juego
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Tablero del Juego</PageTitle>

<div class="tablero-container">
    
    <div class="layout-principal">
        
        <div class="panel-lateral">
            <div class="caja-nombre borde-rosa">
                @Juego.Equipo1
            </div>
            <div class="caja-puntos borde-rosa">
                @Juego.puntosEquipo1
            </div>
            <div class="caja-errores">
                @(Juego.ErroresEquipo1 > 0 ? string.Concat(Enumerable.Repeat("X ", Juego.ErroresEquipo1)) : "Sin errores")
            </div>
        </div>

        <div class="panel-central">
            <div class="circulo-decorativo"></div>

            <div class="contenido-central">
                @if (Juego.PreguntaRevelada || Juego.puntosPartida > 0 || !string.IsNullOrEmpty(Juego.PreguntaActual))
                {
                    string colorMult = Juego.Multiplicador == 3 ? "#D93DAF" : (Juego.Multiplicador == 2 ? "#8124BF" : "#FFCB00");
                    string sombraMult = Juego.Multiplicador == 3 ? "0 0 30px #D93DAF, inset 0 0 15px #D93DAF" : (Juego.Multiplicador == 2 ? "0 0 20px #8124BF, inset 0 0 10px #8124BF" : "0 0 10px rgba(121, 242, 242, 0.5)");
                    string animacionMult = Juego.Multiplicador == 3 ? "latido-fuerte 0.8s infinite" : (Juego.Multiplicador == 2 ? "pulse 1.5s infinite" : "none");

                    <div class="caja-ronda" style="border-color: @colorMult; box-shadow: @sombraMult; color: @colorMult; animation: @animacionMult;">
                        @Juego.puntosPartida
                        <br>
                        
                        @if (Juego.Multiplicador > 1) {
                            <p style="font-size: 20px;">
                                x @Juego.Multiplicador
                            </p>
                        }
                    </div>

                    @if (Juego.PreguntaRevelada)
                    {
                        <h1 class="texto-pregunta">@Juego.PreguntaActual</h1>

                        <div class="contenedor-respuestas-fondo">
                            <div class="respuestas-grid">
                                @for (int i = 0; i < Juego.RespuestasActuales.Count; i++)
                                {
                                    var res = Juego.RespuestasActuales[i];
                                    var estaRevelada = Juego.RespuestasReveladas.Contains(res.res_respuesta);

                                    <div class="caja-respuesta @(estaRevelada ? "revelada" : "oculta")">
                                        <span class="respuesta-texto">@(i + 1). @(estaRevelada ? res.res_respuesta : "_________________")</span>
                                        
                                        @if (estaRevelada)
                                        {
                                            <span class="respuesta-puntos">@Juego.ObtenerPuntosMultiplicados(res.res_cantidad)</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="zona-esperando">
                        <img src="images/logo.png" alt="Logo" class="logo-animado" />
                        <h2 class="texto-esperando">ESPERANDO RONDA...</h2>
                    </div>
                }
            </div>
        </div>

        <div class="panel-lateral">
            <div class="caja-nombre borde-lila">
                @Juego.Equipo2
            </div>
            <div class="caja-puntos borde-lila">
                @Juego.puntosEquipo2
            </div>
            <div class="caja-errores">
                @(Juego.ErroresEquipo2 > 0 ? string.Concat(Enumerable.Repeat("X ", Juego.ErroresEquipo2)) : "Sin errores")
            </div>
        </div>

    </div>

    @if (Juego.MostrarX)
    {
        <div class="pantalla-error">
            <h1 class="x-gigante">X</h1>
        </div>
    }

    @if (Juego.PartidaTerminada)
    {
        <div class="pantalla-fin">
            <h1 class="titulo-fin">¡FIN DE LA PARTIDA!</h1>
            <div class="resumen-fin">
                <div class="caja-fin borde-cian">
                    <h2>@Juego.Equipo1</h2>
                    <p>@Juego.puntosEquipo1</p>
                </div>
                <h1 class="vs-fin">VS</h1>
                <div class="caja-fin borde-rosa">
                    <h2>@Juego.Equipo2</h2>
                    <p>@Juego.puntosEquipo2</p>
                </div>
            </div>
            <h1 class="ganador-fin">
                GANADOR: @(Juego.puntosEquipo1 > Juego.puntosEquipo2 ? Juego.Equipo1 : (Juego.puntosEquipo2 > Juego.puntosEquipo1 ? Juego.Equipo2 : "¡EMPATE!"))
            </h1>
        </div>
    }

    @if (Juego.TimerActivo)
    {
        <div class="timer-overlay">
            <div class="timer-circulo">
                <span class="timer-numero">@Juego.TiempoRestante</span>
                <span class="timer-equipo">@Juego.EquipoConTimer</span>
            </div>
        </div>
    }

    <img src="images/logoItesca.png" alt="Logo Esquina" class="logo-esquina-fijo" />
</div>

<style>
    body, html {
        margin: 0 !important; padding: 0 !important; overflow: hidden !important; background-color: #051026 !important; font-family: 'Roboto', sans-serif;
    }

    .tablero-container {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; overflow: hidden; color: white; z-index: 1;
    }

    .tablero-container::before {
        content: ""; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; z-index: -1;
        background-image: linear-gradient(90deg, rgba(121, 242, 242, 0.2) 2px, transparent 2px), linear-gradient(rgba(121, 242, 242, 0.2) 2px, transparent 2px);
        background-size: 60px 60px; transform: rotate(-30deg); animation: scroll-diagonal 3s linear infinite;
    }

    .layout-principal {
        display: flex; justify-content: space-between; align-items: stretch; width: 100%; height: 100%; padding: 40px; box-sizing: border-box;
    }

    .panel-lateral {
        width: 250px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 15px; z-index: 10;
    }

    .caja-nombre {
        background: rgba(0, 0, 0, 0.75); width: 90%; padding: 10px 20px; text-align: center;
        border-radius: 10px; font-size: 1.5rem; font-weight: bold; text-transform: uppercase;
        box-shadow: 0 5px 15px rgba(0,0,0,0.5); margin-bottom: -5px; z-index: 2;
    }

    .caja-puntos {
        background: rgba(0, 0, 0, 0.6); width: 100%; height: 180px; display: flex; align-items: center; justify-content: center;
        border-radius: 20px; font-size: 5rem; font-weight: bold; box-shadow: 0 10px 20px rgba(0,0,0,0.5); z-index: 1;
    }

    .caja-errores {
        background: rgba(0, 0, 0, 0.4); border: 1px solid rgba(255,0,0,0.4); color: red;
        padding: 5px 15px; border-radius: 8px; font-size: 1.2rem; font-weight: bold;
        text-shadow: 0 0 5px red; margin-top: 5px; opacity: 0.8;
    }

    .borde-cian { border: 2px solid #79F2F2; color: #79F2F2; text-shadow: 0 0 10px #79F2F2; box-shadow: inset 0 0 10px rgba(121, 242, 242, 0.2); }
    .borde-rosa { border: 2px solid #D93DAF; color: #D93DAF; text-shadow: 0 0 10px #D93DAF; box-shadow: inset 0 0 10px rgba(217, 61, 175, 0.2); }
    .borde-amarillo { border: 2px solid #FFCB00; color: #FFCB00; text-shadow: 0 0 10px #FFCB00; box-shadow: inset 0 0 10px rgba(255,255,0,0.5); }
    .borde-lila{ border: 2px solid #5F49F2; color: #5F49F2; text-shadow: 0 0 10px #5F49F2; box-shadow: inset 0 0 10px rgba(72, 62, 140, 0.2); }

    .panel-central {
        flex-grow: 1; position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 0 40px;
    }

    .circulo-decorativo {
        position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
        width: 85vh; height: 85vh; border-radius: 50%; background: rgba(2, 5, 12, 0.55);
        border: 2px solid rgba(129, 36, 191, 0.2); box-shadow: 0 0 60px rgba(0,0,0,0.9), inset 0 0 50px rgba(0,0,0,0.8);
        z-index: 0;
    }

    .contenido-central {
        z-index: 10; width: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center;
    }

    .caja-ronda {
        background: rgba(0, 0, 0, 0.8); border: 3px solid; padding: 15px 50px; border-radius: 15px;
        font-size: 6.5rem; font-weight: bold; text-align: center; margin-bottom: 30px; margin-top: -45px;
        min-width: 180px; background-color: rgba(0,0,0,0.9);
    }

    .texto-pregunta {
        font-size: 2.8rem; text-align: center; text-transform: uppercase; margin-bottom: 30px;
        text-shadow: 2px 2px 5px black, 0 0 10px rgba(255,255,255,0.5); max-width: 90%;
    }

    .contenedor-respuestas-fondo {
        background: rgba(5, 10, 20, 0.85); padding: 30px 40px; border-radius: 20px;
        border: 1px solid rgba(255, 255, 0, 0.1); box-shadow: 0 10px 40px rgba(0,0,0,0.8);
        width: 100%; max-width: 950px;
    }

    .respuestas-grid {
        display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; width: 100%;
    }

    .caja-respuesta {
        height: 65px; border: 2px solid #FFCB00; display: flex; align-items: center; justify-content: space-between;
        padding: 0 20px; font-size: 1.5rem; font-weight: bold; border-radius: 8px; text-shadow: 1px 1px 3px black;
    }

    .caja-respuesta.oculta { 
        background: rgba(0, 0, 0, 0.85); color: #FFCB00; 
        text-shadow: 0 0 8px rgba(255,255,0,0.5); box-shadow: inset 0 0 10px rgba(255,255,0,0.1);
    }
    
    .caja-respuesta.revelada {
        background: linear-gradient(90deg, #D93DAF, #8124BF); color: white;
        box-shadow: 0 0 15px #D93DAF; border: 2px solid #D93DAF;
    }

    .logo-esquina-fijo {
        position: absolute;
        bottom: 20px;     
        left: 20px;       
        width: 120px;     
        height: auto;
        z-index: 50;      
        opacity: 0.7;     
        filter: drop-shadow(0 0 10px rgba(121, 242, 242, 0.4)); 
        pointer-events: none; 
    }

    .timer-overlay {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 2000;
        pointer-events: none;
    }

    .timer-circulo {
        width: 200px;
        height: 200px;
        background: rgba(0, 0, 0, 0.8);
        border: 8px solid #FFCB00;
        border-radius: 50%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 50px #FFCB00;
        animation: pulse-timer 1s infinite;
    }

    .timer-numero {
        font-size: 5rem;
        font-weight: bold;
        color: #FFCB00;
        line-height: 1;
    }

    .timer-equipo {
        font-size: 1.2rem;
        color: white;
        text-transform: uppercase;
        font-weight: bold;
    }

    @@keyframes pulse-timer {
        0% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.1); opacity: 0.9; }
        100% { transform: scale(1); opacity: 1; }
    }


    .respuesta-puntos { border-left: 2px solid rgba(255,255,255,0.5); padding-left: 15px; }

    .zona-esperando { display: flex; flex-direction: column; align-items: center; justify-content: center; }
    .logo-animado { height: 250px; object-fit: contain; animation: pulse 2s infinite; margin-bottom: 20px; filter: drop-shadow(0 0 20px rgba(121, 242, 242, 0.6)); }
    .texto-esperando { color: rgba(121, 242, 242, 0.4); font-size: 1.5rem; letter-spacing: 5px; animation: float-sutil 4s infinite ease-in-out; }

    .pantalla-error { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1000; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.85); }
    .x-gigante { font-size: 35rem; color: #ff0000; text-shadow: 0 0 50px #ff0000, 0 0 100px #ff0000; animation: shake 0.5s; margin: 0; line-height: 1; }
    
    .pantalla-fin { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(5, 16, 38, 0.95); z-index: 999; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; text-align: center; }
    .titulo-fin { font-size: clamp(3rem, 6vw, 6rem); color: #ffff00; text-shadow: 0 0 20px #ffff00; margin-bottom: 20px; }
    .resumen-fin { display: flex; gap: clamp(20px, 4vw, 80px); margin: 40px 0; align-items: center; justify-content: center; flex-wrap: wrap; }
    .caja-fin { text-align: center; padding: clamp(20px, 3vw, 40px); border-radius: 20px; background: rgba(0,0,0,0.5); min-width: 250px; }
    .caja-fin h2 { font-size: clamp(2rem, 4vw, 3.5rem); margin-bottom: 10px; text-transform: uppercase; }
    .caja-fin p { font-size: clamp(3.5rem, 6vw, 6rem); font-weight: bold; margin: 0; color: white;}
    .vs-fin { font-size: clamp(3rem, 5vw, 5rem); text-shadow: 0 0 15px white; }
    .ganador-fin { text-transform: uppercase; font-size: clamp(2rem, 4vw, 4rem); background: #ffff00; color: black; padding: 15px clamp(20px, 4vw, 50px); border-radius: 50px; animation: pulse 1s infinite; box-shadow: 0 0 30px #ffff00; margin-top: 20px;}

    @@keyframes scroll-diagonal { 0% { background-position: 0 0; } 100% { background-position: 60px 60px; } }
    @@keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }
    @@keyframes latido-fuerte { 0% { transform: scale(1); } 20% { transform: scale(1.15); } 40% { transform: scale(1); } 60% { transform: scale(1.15); } 100% { transform: scale(1); } }
    @@keyframes float-sutil { 0% { transform: translateY(0px); opacity: 0.5; } 50% { transform: translateY(-10px); opacity: 0.8; } 100% { transform: translateY(0px); opacity: 0.5; } }
    @@keyframes shake { 0% { transform: translate(1px, 1px) rotate(0deg); } 10% { transform: translate(-10px, -10px) rotate(-3deg); } 30% { transform: translate(10px, 10px) rotate(3deg); } 50% { transform: translate(-10px, 10px) rotate(-3deg); } 100% { transform: translate(1px, -1px) rotate(0deg); } }
</style>

@code {
    protected override void OnInitialized()
    {
        Juego.OnChange += ManejarCambioEstado;
    }

    private async void ManejarCambioEstado()
    {
        try { await InvokeAsync(StateHasChanged); } catch (Exception) { }
    }

    public void Dispose()
    {
        Juego.OnChange -= ManejarCambioEstado;
    }
}